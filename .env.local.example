# ─────────────────────────────────────────────
# AVI — Variables de entorno
# Copiar este archivo a .env.local y completar
# ─────────────────────────────────────────────

# Supabase (obtener en: supabase.com → proyecto → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Solo para webhooks, NUNCA exponerla al cliente

# Anthropic Claude API (obtener en: console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Upstash Redis — rate limiting (obtener en: upstash.com) — Sprint 3
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Stripe — pagos (obtener en: stripe.com) — Sprint 5
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# URL pública de la app
NEXT_PUBLIC_APP_URL=http://localhost:3000
